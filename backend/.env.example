NODE_ENV=development
PORT=5000

# Database
# Preferred for cloud hosts (Neon/Supabase/Render Postgres)
# Example: postgres://user:pass@host:5432/dbname
DATABASE_URL=
# Set DB_SSL=require for cloud Postgres providers
DB_SSL=false

# Fallback split DB settings (used when DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=toplis_logistics
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# AWS S3 or MinIO
USE_MINIO=true
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=toplis-docs

# Email (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Socket.IO
SOCKET_IO_CORS=http://localhost:3000

# Frontend origin (set to your deployed frontend URL in production)
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug
